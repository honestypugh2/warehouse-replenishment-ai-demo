# ─────────────────────────────────────────────────────────────
# Modes
#   Data systems (Databricks + D365) are ALWAYS mocked in this demo.
#   MOCK_MODE controls those mocked data systems (keep true).
#
#   FOUNDRY_MODE selects how recommendations are narrated:
#     mock -> deterministic local template (no Azure calls, fully offline)
#     live -> real Azure AI Foundry model (needs the vars below + `az login`)
#   The React app can also switch per-request once live is configured.
# ─────────────────────────────────────────────────────────────
MOCK_MODE=true
FOUNDRY_MODE=mock

# When true (and FOUNDRY_MODE=live), live narration is produced by a *persistent
# Foundry agent* (created by scripts/provision_foundry_agents.py, visible in the
# portal Agents list) instead of a raw chat completion. Falls back to the chat
# completion, then the offline template, if the agent path is unavailable.
FOUNDRY_USE_AGENTS=false

# CORS origins for the React dev server (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── Microsoft Foundry (Azure AI Foundry) ───────────────────────
# Required only for FOUNDRY_MODE=live. Auth uses DefaultAzureCredential
# (run `az login`, or a managed identity in Azure) — no keys needed.
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry>.services.ai.azure.com/api/projects/<project>
AZURE_FOUNDRY_MODEL_DEPLOYMENT=gpt-4o
AZURE_FOUNDRY_API_VERSION=2024-10-21
AZURE_TENANT_ID=<tenant-id>

# ─── Tracing + monitoring (Application Insights) ─────────────────
# Set to export OpenTelemetry GenAI/workflow traces to App Insights. azd writes
# this automatically (the same resource is connected to the Foundry project, so
# the portal Tracing / Monitoring tabs show the agent runs). Leave empty offline.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ─── Databricks (system of intelligence) ────────────────────────
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
DATABRICKS_WAREHOUSE_ID=<warehouse-id>
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
DATABRICKS_TOKEN=<token>   # use a managed identity in production

# ─── D365 F&O (system of record) / MCP write path ───────────────
D365_BASE_URL=https://<env>.operations.dynamics.com
D365_MCP_ENDPOINT=https://<mcp-host>/mcp
D365_CLIENT_ID=<app-id>
D365_CLIENT_SECRET=<secret>   # use a managed identity / Key Vault in production

# ─── Approval channel (Microsoft Teams) ─────────────────────────
TEAMS_APPROVAL_WEBHOOK=<incoming-webhook>
